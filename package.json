{
  "name": "rm-pushnotify",
  "version": "2.0.0",
  "description": "Lightweight, zero-dependency library for handling Web Push notifications and service workers in PWAs and modern web apps. Easy registration, subscription, and notification management with full TypeScript support.",
  "main": "./dist/rm-pushnotify.cjs",
  "module": "./dist/rm-pushnotify.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rm-pushnotify.esm.js",
      "require": "./dist/rm-pushnotify.cjs"
    }
  },
  "type": "module",
  "keywords": [
